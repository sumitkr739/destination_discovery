generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]

  @@index([email])
  @@map("users")
}

model Trip {
  id                String   @id @default(uuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination       String
  budget            String
  duration          String
  personality       String
  interests         String[]
  story             String   @db.Text
  hiddenGems        Json
  foodPassport      Json
  culturalEtiquette Json
  festivals         Json
  souvenirs         Json
  phrases           Json
  packingList       Json
  timeline          Json
  attractions       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([createdAt])
  @@index([userId])
  @@map("trips")
}
